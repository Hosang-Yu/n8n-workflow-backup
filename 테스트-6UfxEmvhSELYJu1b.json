y}-${mm}-${dd} ${hh}:${min}:${ss}`;\n\n  // 파일명 전처리\n  function normalizeFileName(name) {\n      return name\n          ?.replace(/[\\n\\r\\t]/g, \"\")\n          .replace(/\\(파일크기:\\s*[\\d\\.]+[KMG]?B\\s*\\)$/i, \"\")\n          .replace(/\\s*\\([\\d\\.]+\\s*[KMG]B\\)\\s*$/i, \"\")\n          .trim();\n  }\n\n  // ⭐ ajaxFileDownLoad('325068','1') → { fileId, fileSeq }\n  function parseAjax(address) {\n      const m = (address || '').match(/ajaxFileDownLoad\\('(\\d+)'\\s*,\\s*'(\\d+)'\\)/);\n      return m ? { fileId: m[1], fileSeq: m[2] } : { fileId: null, fileSeq: null };\n  }\n\n  // 주소 → 다운로드 URL 변환 (DB 저장용)\n  function extractFileUrl(address) {\n      if (!address) return null;\n\n      // ⭐ ajaxFileDownLoad 패턴\n      let match = address.match(/ajaxFileDownLoad\\('(\\d+)'\\s*,\\s*'(\\d+)'\\)/);\n      if (match) {\n          return `${baseUrl}/home/file/readDownloadFile4.do?fileId=${match[1]}&fileSeq=${match[2]}`;\n      }\n\n      match = address.match(/download\\('(\\d+)'\\)/);\n      if (match) return `${baseUrl}/_custom/cms/_common/board/fira.jsp?attach_no=${match[1]}`;\n\n      match = address.match(/fn_egov_downFile\\('([^']+)','([^']+)'/);\n      if (match) return `${baseUrl}/cmm/fms/FileDown.do?atchFileId=${encodeURIComponent(match[1])}&fileSn=${encodeURIComponent(match[2])}`;\n\n      match = address.match(/yhLib\\.file\\.download\\('([^']+)'/);\n      if (match) return `${baseUrl}/download.action?attachId=${match[1]}`;\n\n      if (address.startsWith(\"./\")) return baseUrl + address.substring(1);\n      if (address.startsWith(\"http\")) return address;\n      return `${baseUrl}${address}`;\n  }\n\n  // 파일 분류\n  for (let i = 0; i < names.length; i++) {\n      const name = normalizeFileName(names[i]);\n      const fileUrl = extractFileUrl(addresses[i]);\n      const { fileId, fileSeq } = parseAjax(addresses[i]);   // ⭐\n      if (!name || !fileUrl) continue;\n\n      if (name.toLowerCase().endsWith(\".zip\")) {\n          extraFileNames.push(name);\n          extraFilePaths.push(fileUrl);\n          continue;\n      }\n\n      if (name.includes(\"공고\") && !noticeFileName) {\n          noticeFileName = name;\n          noticeFileAddress = fileUrl;\n          noticeFileId = fileId;       // ⭐\n          noticeFileSeq = fileSeq;     // ⭐\n          announcement_file_exist = true;\n      } else {\n          extraFileNames.push(name);\n          extraFilePaths.push(fileUrl);\n      }\n  }\n\n  // 공고 파일 없으면 첫 비-zip 파일로 대체\n  if (!noticeFileName && names.length > 0) {\n      for (let i = 0; i < names.length; i++) {\n          const candidateName = normalizeFileName(names[i]);\n          const candidateUrl = extractFileUrl(addresses[i]);\n          const { fileId, fileSeq } = parseAjax(addresses[i]);   // ⭐\n          if (candidateName && !candidateName.toLowerCase().endsWith(\".zip\")) {\n              noticeFileName = candidateName;\n              noticeFileAddress = candidateUrl;\n              noticeFileId = fileId;       // ⭐\n              noticeFileSeq = fileSeq;     // ⭐\n              break;\n          }\n      }\n  }\n\n  // 최종 리턴\n  return [{\n      json: {\n          fileName: noticeFileName,\n          fileAddress: noticeFileAddress,\n          fileId: noticeFileId,       // ⭐ 추가\n          fileSeq: noticeFileSeq,     // ⭐ 추가\n          file_nm: extraFileNames.join(\"@\"),\n          flpth_nm: extraFilePaths.join(\"@\"),\n          announcement_file_exist: announcement_file_exist,\n          creat_p_nttm: formatted,\n          created_ts: formatted\n      }\n  }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-3888,608],"id":"18d395a9-7b53-4690-a9e1-7634c1b70145","name":"pdf,첨부파일분리"},{"parameters":{"url":"https://mcee.go.kr/home/web/index.do","sendQuery":true,"queryParameters":{"parameters":[{"name":"menuId","value":"10524"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"User-Agent","value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:143.0) Gecko/20100101 Firefox/143.0"},{"nam